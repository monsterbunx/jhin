#!/bin/bash
# jhin/nodejs — instalador Node.js vía tar.xz desde nodejs.org.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/nodejs) [lang] [-v]

LANG_ARG=""
VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    -v|--verbose) VERBOSE=1 ;;
    -h|--help) echo "uso: nodejs [lang] [-v]"; return 0 2>/dev/null || exit 0 ;;
    *) [ -z "$LANG_ARG" ] && LANG_ARG="$arg" ;;
  esac
done
LANG_ARG="${LANG_ARG:-es}"

JHIN_BASE="${JHIN_BASE:-https://monsterbunx.github.io/jhin}"
. <(curl -fsSL "$JHIN_BASE/XT/pm.sh")
. <(curl -fsSL "$JHIN_BASE/XT/nodejs") "$LANG_ARG"

say()  { printf '%b\n' "$1"; }
run()  { if [ "$VERBOSE" = "1" ]; then "$@"; else "$@" >/dev/null 2>&1; fi; }

# Alpine usa musl: los tarballs glibc de nodejs.org no ejecutan. Usar el paquete
# de la distro (compilado contra musl). Cede control de versión a Alpine.
if [ "$JHIN_OS" = "alpine" ]; then
  say "$XT_TITLE"
  say "$XT_DEPS"
  run pm_update
  run pm_install nodejs npm
  say "$XT_DONE"
  node -v; npm -v
  return 0 2>/dev/null || exit 0
fi

# Node publica como linux-x64 / linux-arm64.
case "$JHIN_ARCH" in
  amd64) NODE_ARCH="x64" ;;
  arm64) NODE_ARCH="arm64" ;;
  *)     jhin_unsupported_arch; return 1 2>/dev/null || exit 1 ;;
esac

# xz-utils en Debian; xz en el resto.
case "$JHIN_PM" in
  apt) XZ_PKG="xz-utils" ;;
  *)   XZ_PKG="xz" ;;
esac

say "$XT_TITLE"

say "$XT_DEPS"
run pm_update
run pm_install curl ca-certificates "$XZ_PKG"

rm -rf /usr/local/node

td=$(mktemp -d)
say "$XT_DOWNLOAD"
run curl -L -o "$td/node.tar.xz" "https://nodejs.org/dist/v22.15.1/node-v22.15.1-linux-${NODE_ARCH}.tar.xz"

say "$XT_EXTRACT"
run tar -xJf "$td/node.tar.xz" -C "$td"

say "$XT_INSTALL"
mv "$td"/node-v*/ /usr/local/node
rm -rf "$td"

say "$XT_PATH"
echo 'export PATH=/usr/local/node/bin:$PATH' >> ~/.bashrc
export PATH=/usr/local/node/bin:$PATH

say "$XT_DONE"
node -v
npm -v

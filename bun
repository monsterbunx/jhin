#!/bin/bash
# jhin/bun — instalador Bun vía bun.sh/install.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/bun) [lang] [-v]

LANG_ARG=""
VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    -v|--verbose) VERBOSE=1 ;;
    -h|--help) echo "uso: bun [lang] [-v]"; return 0 2>/dev/null || exit 0 ;;
    *) [ -z "$LANG_ARG" ] && LANG_ARG="$arg" ;;
  esac
done
LANG_ARG="${LANG_ARG:-es}"

JHIN_BASE="${JHIN_BASE:-https://monsterbunx.github.io/jhin}"
. <(curl -fsSL "$JHIN_BASE/XT/pm.sh")
. <(curl -fsSL "$JHIN_BASE/XT/bun") "$LANG_ARG"

say()  { printf '%b\n' "$1"; }
run()  { if [ "$VERBOSE" = "1" ]; then "$@"; else "$@" >/dev/null 2>&1; fi; }

say "$XT_TITLE"

say "$XT_DEPS"
run pm_update
# Alpine: el binario musl de bun necesita libstdc++ y libgcc (símbolos
# _Unwind_* y __cxxabiv* en runtime).
case "$JHIN_PM" in
  apk) DEPS="curl unzip ca-certificates libstdc++ libgcc" ;;
  *)   DEPS="curl unzip ca-certificates" ;;
esac
run pm_install $DEPS

say "$XT_INSTALL"
if [ "$VERBOSE" = "1" ]; then
  curl -fsSL https://bun.sh/install | bash
else
  curl -fsSL https://bun.sh/install | bash >/dev/null 2>&1
fi

say "$XT_PATH"
export PATH="$HOME/.bun/bin:$PATH"

say "$XT_DONE"
"$HOME/.bun/bin/bun" --version

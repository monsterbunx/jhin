#!/bin/bash
# jhin/postgres — instalador PostgreSQL server + client vía apt.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/postgres) [lang] [-v]

LANG_ARG=""
VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    -v|--verbose) VERBOSE=1 ;;
    -h|--help) echo "uso: postgres [lang] [-v]"; return 0 2>/dev/null || exit 0 ;;
    *) [ -z "$LANG_ARG" ] && LANG_ARG="$arg" ;;
  esac
done
LANG_ARG="${LANG_ARG:-es}"

JHIN_BASE="${JHIN_BASE:-https://monsterbunx.github.io/jhin}"
. <(curl -fsSL "$JHIN_BASE/XT/pm.sh")
. <(curl -fsSL "$JHIN_BASE/XT/postgres") "$LANG_ARG"

say()  { printf '%b\n' "$1"; }
run()  { if [ "$VERBOSE" = "1" ]; then "$@"; else "$@" >/dev/null 2>&1; fi; }

say "$XT_TITLE"
say "$XT_DEPS"
run pm_update
case "$JHIN_PM" in
  apt)    DEPS="postgresql postgresql-contrib" ;;
  dnf)    DEPS="postgresql postgresql-server postgresql-contrib" ;;
  apk)    DEPS="postgresql postgresql-client postgresql-contrib" ;;
  pacman) DEPS="postgresql" ;;
esac
run pm_install $DEPS

say "$XT_NOTE"
say "$XT_DONE"
psql --version
pg_config --version 2>/dev/null || true

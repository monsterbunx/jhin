#!/bin/bash
# jhin/python — compilación de Python desde fuente python.org.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/python) [lang] [-v]

LANG_ARG=""
VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    -v|--verbose) VERBOSE=1 ;;
    -h|--help) echo "uso: python [lang] [-v]"; return 0 2>/dev/null || exit 0 ;;
    *) [ -z "$LANG_ARG" ] && LANG_ARG="$arg" ;;
  esac
done
LANG_ARG="${LANG_ARG:-es}"

JHIN_BASE="${JHIN_BASE:-https://monsterbunx.github.io/jhin}"
. <(curl -fsSL "$JHIN_BASE/XT/pm.sh")
. <(curl -fsSL "$JHIN_BASE/XT/python") "$LANG_ARG"

say()  { printf '%b\n' "$1"; }
sayf() { local f="$1"; shift; printf '%b\n' "$(printf "$f" "$@")"; }
run()  { if [ "$VERBOSE" = "1" ]; then "$@"; else "$@" >/dev/null 2>&1; fi; }

# Dependencias de build de CPython por distro (los -dev/-devel divergen).
case "$JHIN_PM" in
  apt)    DEPS="build-essential wget curl libssl-dev zlib1g-dev libbz2-dev libreadline-dev libsqlite3-dev llvm libncurses-dev xz-utils tk-dev libffi-dev liblzma-dev libgdbm-dev libdb-dev" ;;
  dnf)    DEPS="gcc gcc-c++ make wget curl openssl-devel zlib-devel bzip2-devel readline-devel sqlite-devel llvm ncurses-devel xz xz-devel tk-devel libffi-devel gdbm-devel libdb-devel" ;;
  apk)    DEPS="build-base wget curl openssl-dev zlib-dev bzip2-dev readline-dev sqlite-dev llvm ncurses-dev xz xz-dev tk-dev libffi-dev gdbm-dev db-dev" ;;
  pacman) DEPS="base-devel wget curl openssl zlib bzip2 readline sqlite llvm ncurses xz tk libffi gdbm" ;;
esac

say "$XT_TITLE"

say "$XT_DEPS"
run pm_update
run pm_install $DEPS

base="https://www.python.org/ftp/python"
say "$XT_FETCH_VERSION"
# grep -oE (busybox/Alpine sin PCRE): versiones X.Y.Z seguidas de '/'.
version=$(curl -s "$base/" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+/' | sed 's:/::' | sort -u -Vr | sed -n '2p')
sayf "$XT_VERSION" "$version"

td=$(mktemp -d)
sayf "$XT_DOWNLOAD" "$version"
run curl -L -o "$td/Python-$version.tar.xz" "$base/$version/Python-$version.tar.xz"

run tar -xJf "$td/Python-$version.tar.xz" -C "$td"
cd "$td/Python-$version" || return 1

say "$XT_CONFIGURE"
run ./configure --enable-optimizations

say "$XT_BUILD"
run make -j"$(nproc)"

say "$XT_INSTALL"
run make install

cd ~ || return 1
rm -rf "$td"

echo "alias python='/usr/local/bin/python3.${version%.*}'" 2>/dev/null
echo 'export PATH=/usr/local/bin:$PATH' >> ~/.bashrc
export PATH=/usr/local/bin:$PATH

say "$XT_DONE"
python3 --version 2>/dev/null || /usr/local/bin/python3.* --version 2>/dev/null | head -1

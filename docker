#!/bin/bash
# jhin/docker — instalador Docker Engine vía .deb stable de download.docker.com.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/docker) [lang] [-v]
#   lang: idioma de los mensajes (default: es). -v: muestra salida de comandos.

# --- args ---
LANG_ARG=""
VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    -v|--verbose) VERBOSE=1 ;;
    -h|--help) echo "uso: docker [lang] [-v]"; return 0 2>/dev/null || exit 0 ;;
    *) [ -z "$LANG_ARG" ] && LANG_ARG="$arg" ;;
  esac
done
LANG_ARG="${LANG_ARG:-es}"

# --- carga pm.sh + klors + strings i18n ---
JHIN_BASE="${JHIN_BASE:-https://monsterbunx.github.io/jhin}"
. <(curl -fsSL "$JHIN_BASE/XT/pm.sh")
. <(curl -fsSL "$JHIN_BASE/XT/docker") "$LANG_ARG"

# --- helpers ---
say()  { printf '%b\n' "$1"; }
sayf() { local f="$1"; shift; printf '%b\n' "$(printf "$f" "$@")"; }
run()  { if [ "$VERBOSE" = "1" ]; then "$@"; else "$@" >/dev/null 2>&1; fi; }

# --- install ---
say "$XT_TITLE"
sayf "$XT_OS_DETECTED" "$JHIN_OS" "-" "$JHIN_ARCH"

# Alpine: Docker está en el repo community (apk). Resto: script oficial
# get.docker.com (maneja debian/ubuntu/fedora/centos + arch automáticamente).
say "$XT_INSTALL"
if [ "$JHIN_OS" = "alpine" ]; then
  run pm_update
  run pm_install docker docker-cli docker-cli-compose
else
  run pm_update
  run pm_install curl ca-certificates
  if [ "$VERBOSE" = "1" ]; then
    curl -fsSL https://get.docker.com | sh
  else
    curl -fsSL https://get.docker.com | sh >/dev/null 2>&1
  fi
fi

# DinD support: si corremos dentro de un contenedor, no hay systemd que arranque
# dockerd tras el dpkg. Lo lanzamos en background y esperamos al socket.
# Usa 'vfs' como storage-driver para evitar el conflicto overlay-sobre-overlay.
if [ -f /.dockerenv ] || grep -qE 'docker|containerd' /proc/1/cgroup 2>/dev/null; then
  if [ ! -S /var/run/docker.sock ]; then
    say "$XT_DIND_DETECTED"
    say "$XT_DAEMON_START"
    mkdir -p /etc/docker
    echo '{"storage-driver":"vfs"}' >/etc/docker/daemon.json
    nohup dockerd >/var/log/dockerd.log 2>&1 &
    say "$XT_DAEMON_WAIT"
    for _ in $(seq 1 30); do
      [ -S /var/run/docker.sock ] && break
      sleep 1
    done
    if [ -S /var/run/docker.sock ]; then
      say "$XT_DAEMON_OK"
    else
      say "$XT_DAEMON_FAIL"
    fi
  fi
fi

say "$XT_DONE"
# `docker version` (cliente+servidor) requiere daemon; en instalación sin
# privilegios mostramos sólo el cliente. El daemon lo arranca el bloque DinD
# de arriba cuando hay privilegios.
docker --version
docker version 2>/dev/null || true

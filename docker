#!/bin/bash
# jhin/docker — instalador Docker Engine vía .deb stable de download.docker.com.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/docker) [lang] [-v]
#   lang: idioma de los mensajes (default: es). -v: muestra salida de comandos.

# --- args ---
LANG_ARG=""
VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    -v|--verbose) VERBOSE=1 ;;
    -h|--help) echo "uso: docker [lang] [-v]"; return 0 2>/dev/null || exit 0 ;;
    *) [ -z "$LANG_ARG" ] && LANG_ARG="$arg" ;;
  esac
done
LANG_ARG="${LANG_ARG:-es}"

# --- carga klors + strings i18n ---
. <(curl -fsSL https://monsterbunx.github.io/jhin/xt-docker) "$LANG_ARG"

# --- helpers ---
say()  { printf '%b\n' "$1"; }
sayf() { local f="$1"; shift; printf '%b\n' "$(printf "$f" "$@")"; }
run()  { if [ "$VERBOSE" = "1" ]; then "$@"; else "$@" >/dev/null 2>&1; fi; }

# --- install ---
say "$XT_TITLE"
say "$XT_DEPS_CHECK"

check(){
  if dpkg -l "$1" 2>/dev/null | grep -q '^ii'; then
    sayf "$XT_DEP_OK" "$1"
  else
    sayf "$XT_DEP_INSTALL" "$1"
    run apt install -y "$1"
  fi
}

check iptables
check curl
check dbus-user-session

sabor=$(grep 'VERSION_CODENAME' /etc/os-release | cut -d= -f2)
so=$(grep '^ID=' /etc/os-release | cut -d= -f2)
arch=$(dpkg --print-architecture)
sayf "$XT_OS_DETECTED" "$so" "$sabor" "$arch"

url="https://download.docker.com/linux/$so/dists/$sabor/pool/stable/$arch"

say "$XT_LIST_INDEX"
content=$(curl -s "$url/")

td=$(mktemp -d)
Dwnld(){
  local pkg="$1"
  local names=$(echo "$content" | grep -oP '(?<=href=")[^"]*'"$pkg"'[^"]*\.deb' | sort -V | tail -n 1)
  sayf "$XT_DOWNLOAD" "$names"
  run curl -L -o "$td/$names" "$url/$names"
  sayf "$XT_INSTALL_DEB" "$names"
  run dpkg -i "$td/$names"
}

Dwnld containerd
Dwnld docker-buildx-plugin
Dwnld docker-ce-cli
Dwnld docker-ce-rootless-extras
Dwnld docker-ce
Dwnld docker-compose-plugin
Dwnld docker-scan-plugin
Dwnld docker-model-plugin

rm -rf "$td"

say "$XT_FIX_BROKEN"
run apt --fix-broken install -y

# DinD support: si corremos dentro de un contenedor, no hay systemd que arranque
# dockerd tras el dpkg. Lo lanzamos en background y esperamos al socket.
# Usa 'vfs' como storage-driver para evitar el conflicto overlay-sobre-overlay.
if [ -f /.dockerenv ] || grep -qE 'docker|containerd' /proc/1/cgroup 2>/dev/null; then
  if [ ! -S /var/run/docker.sock ]; then
    say "$XT_DIND_DETECTED"
    say "$XT_DAEMON_START"
    mkdir -p /etc/docker
    echo '{"storage-driver":"vfs"}' >/etc/docker/daemon.json
    nohup dockerd >/var/log/dockerd.log 2>&1 &
    say "$XT_DAEMON_WAIT"
    for _ in $(seq 1 30); do
      [ -S /var/run/docker.sock ] && break
      sleep 1
    done
    if [ -S /var/run/docker.sock ]; then
      say "$XT_DAEMON_OK"
    else
      say "$XT_DAEMON_FAIL"
    fi
  fi
fi

say "$XT_DONE"
docker version

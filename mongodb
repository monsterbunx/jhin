#!/bin/bash
# jhin/mongodb — cliente mongosh vía repo oficial MongoDB (apt).
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/mongodb) [lang] [-v]

LANG_ARG=""
VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    -v|--verbose) VERBOSE=1 ;;
    -h|--help) echo "uso: mongodb [lang] [-v]"; return 0 2>/dev/null || exit 0 ;;
    *) [ -z "$LANG_ARG" ] && LANG_ARG="$arg" ;;
  esac
done
LANG_ARG="${LANG_ARG:-es}"

JHIN_BASE="${JHIN_BASE:-https://monsterbunx.github.io/jhin}"
. <(curl -fsSL "$JHIN_BASE/XT/pm.sh")
. <(curl -fsSL "$JHIN_BASE/XT/mongodb") "$LANG_ARG"

say()  { printf '%b\n' "$1"; }
run()  { if [ "$VERBOSE" = "1" ]; then "$@"; else "$@" >/dev/null 2>&1; fi; }

say "$XT_TITLE"

# mongosh es glibc → no hay camino musl en Alpine:
#   - apk sólo trae `mongodb-tools` (dump/export/import/...), NO el shell mongosh.
#   - Todos los tarballs de github.com/mongodb-js/mongosh son glibc (x64/arm64/...).
#   - gcompat carga el binario pero faltan los símbolos del resolver de glibc
#     (__res_nsearch / __dn_expand) → error de relocación al cargar.
#   - La shim de glibc (sgerrand 2.35, discontinuada) segfaultea con el runtime
#     Node moderno de mongosh.
#   - `npm install -g mongosh` crashea por bindings nativos musl.
# → Alpine no soportado (cae al caso *).
case "$JHIN_PM" in
  apt)
    say "$XT_DEPS"
    run pm_update
    run pm_install curl gnupg ca-certificates
    CODENAME="$(. /etc/os-release && echo "$VERSION_CODENAME")"
    case "$CODENAME" in
      bookworm|bullseye|trixie) ;;
      *) CODENAME=bookworm ;;
    esac
    run curl -fsSL https://www.mongodb.org/static/pgp/server-7.0.asc -o /tmp/mongo.asc
    run bash -c "gpg --dearmor < /tmp/mongo.asc > /usr/share/keyrings/mongodb-server-7.0.gpg"
    echo "deb [signed-by=/usr/share/keyrings/mongodb-server-7.0.gpg] http://repo.mongodb.org/apt/debian ${CODENAME}/mongodb-org/7.0 main" > /etc/apt/sources.list.d/mongodb-org-7.0.list
    say "$XT_INSTALL"
    run apt-get ${JHIN_APT_OPTS:-} update
    run pm_install mongodb-mongosh
    ;;
  dnf)
    case "$JHIN_ARCH" in amd64) MA="x86_64" ;; arm64) MA="aarch64" ;; *) jhin_unsupported_arch; return 1 2>/dev/null || exit 1 ;; esac
    say "$XT_REPO_ADD"
    cat > /etc/yum.repos.d/mongodb-org-7.0.repo <<EOF
[mongodb-org-7.0]
name=MongoDB Repository
baseurl=https://repo.mongodb.org/yum/redhat/9/mongodb-org/7.0/${MA}/
gpgcheck=1
enabled=1
gpgkey=https://pgp.mongodb.com/server-7.0.asc
EOF
    say "$XT_INSTALL"
    run pm_install mongodb-mongosh
    ;;
  *)
    say "✗ mongodb: mongosh sólo glibc (apt/dnf). $JHIN_OS no soportado."
    return 1 2>/dev/null || exit 1
    ;;
esac

say "$XT_NOTE"
say "$XT_DONE"
mongosh --version

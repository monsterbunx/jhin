#!/bin/bash
# jhin/terraform — Terraform vía zip estático oficial (cross-distro + multi-arch).
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/terraform) [lang] [-v]

LANG_ARG=""
VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    -v|--verbose) VERBOSE=1 ;;
    -h|--help) echo "uso: terraform [lang] [-v]"; return 0 2>/dev/null || exit 0 ;;
    *) [ -z "$LANG_ARG" ] && LANG_ARG="$arg" ;;
  esac
done
LANG_ARG="${LANG_ARG:-es}"

JHIN_BASE="${JHIN_BASE:-https://monsterbunx.github.io/jhin}"
. <(curl -fsSL "$JHIN_BASE/XT/pm.sh")
. <(curl -fsSL "$JHIN_BASE/XT/terraform") "$LANG_ARG"

say()  { printf '%b\n' "$1"; }
run()  { if [ "$VERBOSE" = "1" ]; then "$@"; else "$@" >/dev/null 2>&1; fi; }

# El zip oficial es un binario Go estático → cualquier distro/arch, sin repo apt.
case "$JHIN_ARCH" in
  amd64) TF_ARCH="amd64" ;;
  arm64) TF_ARCH="arm64" ;;
  armhf) TF_ARCH="arm" ;;
  *)     jhin_unsupported_arch; return 1 2>/dev/null || exit 1 ;;
esac

say "$XT_TITLE"
say "$XT_DEPS"
run pm_update
run pm_install curl ca-certificates unzip

say "$XT_INSTALL"
TF_VER=$(curl -fsSL "https://api.releases.hashicorp.com/v1/releases/terraform/latest" | grep -oE '"version":"[0-9.]+"' | head -1 | sed -E 's/.*"([0-9.]+)".*/\1/')
td=$(mktemp -d)
run curl -fL -o "$td/tf.zip" "https://releases.hashicorp.com/terraform/${TF_VER}/terraform_${TF_VER}_linux_${TF_ARCH}.zip"
run unzip -o "$td/tf.zip" -d /usr/local/bin
chmod +x /usr/local/bin/terraform
rm -rf "$td"

say "$XT_DONE"
terraform --version | head -1

#!/bin/bash
# jhin/terraform — instalador Terraform vía repo HashiCorp.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/terraform) [lang] [-v]

LANG_ARG=""
VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    -v|--verbose) VERBOSE=1 ;;
    -h|--help) echo "uso: terraform [lang] [-v]"; return 0 2>/dev/null || exit 0 ;;
    *) [ -z "$LANG_ARG" ] && LANG_ARG="$arg" ;;
  esac
done
LANG_ARG="${LANG_ARG:-es}"

. <(curl -fsSL https://monsterbunx.github.io/jhin/XT/terraform) "$LANG_ARG"

say()  { printf '%b\n' "$1"; }
run()  { if [ "$VERBOSE" = "1" ]; then "$@"; else "$@" >/dev/null 2>&1; fi; }

say "$XT_TITLE"

say "$XT_DEPS"
run apt update
run apt install -y gnupg lsb-release ca-certificates curl

say "$XT_KEYRING"
run curl -fsSL https://apt.releases.hashicorp.com/gpg -o /tmp/hashicorp.gpg.key
gpg --batch --yes --dearmor < /tmp/hashicorp.gpg.key > /usr/share/keyrings/hashicorp-archive-keyring.gpg
rm -f /tmp/hashicorp.gpg.key

say "$XT_REPO_ADD"
echo "deb [signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(lsb_release -cs) main" > /etc/apt/sources.list.d/hashicorp.list

say "$XT_REPO_UPDATE"
run apt update

say "$XT_INSTALL"
run apt install -y terraform

say "$XT_DONE"
terraform --version | head -1

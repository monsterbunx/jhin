# XT/git — carga klors + strings i18n de xtractor para el instalador git.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/XT/git) [lang]
_lang="${1:-es}"
. <(curl -fsSL https://monsterbunx.github.io/klors/klors)
. <(curl -fsSL "https://monsterbunx.github.io/xtractor/git/$_lang") 2>/dev/null \
  || . <(curl -fsSL https://monsterbunx.github.io/xtractor/git/es)
unset _lang

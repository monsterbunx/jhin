# XT/sql — carga klors + strings i18n de xtractor para el instalador sql.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/XT/sql) [lang]
_lang="${1:-es}"
. <(curl -fsSL https://monsterbunx.github.io/klors/klors)
. <(curl -fsSL "https://monsterbunx.github.io/xtractor/sql/$_lang") 2>/dev/null \
  || . <(curl -fsSL https://monsterbunx.github.io/xtractor/sql/es)
unset _lang

# XT/rust — carga klors + strings i18n de xtractor para el instalador rust.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/XT/rust) [lang]
_lang="${1:-es}"
. <(curl -fsSL https://monsterbunx.github.io/klors/klors)
. <(curl -fsSL "https://monsterbunx.github.io/xtractor/rust/$_lang") 2>/dev/null \
  || . <(curl -fsSL https://monsterbunx.github.io/xtractor/rust/es)
unset _lang

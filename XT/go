# XT/go — carga klors + strings i18n de xtractor para el instalador go.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/XT/go) [lang]
_lang="${1:-es}"
. <(curl -fsSL https://monsterbunx.github.io/klors/klors)
. <(curl -fsSL "https://monsterbunx.github.io/xtractor/go/$_lang") 2>/dev/null \
  || . <(curl -fsSL https://monsterbunx.github.io/xtractor/go/es)
unset _lang

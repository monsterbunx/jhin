# XT/dotnet — carga klors + strings i18n de xtractor para el instalador dotnet.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/XT/dotnet) [lang]
_lang="${1:-es}"
. <(curl -fsSL https://monsterbunx.github.io/klors/klors)
. <(curl -fsSL "https://monsterbunx.github.io/xtractor/dotnet/$_lang") 2>/dev/null \
  || . <(curl -fsSL https://monsterbunx.github.io/xtractor/dotnet/es)
unset _lang

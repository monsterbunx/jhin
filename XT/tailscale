# XT/tailscale — carga klors + strings i18n de xtractor para el instalador tailscale.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/XT/tailscale) [lang]
_lang="${1:-es}"
. <(curl -fsSL https://monsterbunx.github.io/klors/klors)
. <(curl -fsSL "https://monsterbunx.github.io/xtractor/tailscale/$_lang") 2>/dev/null \
  || . <(curl -fsSL https://monsterbunx.github.io/xtractor/tailscale/es)
unset _lang

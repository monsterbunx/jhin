# XT/haskell — carga klors + strings i18n de xtractor para el instalador haskell.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/XT/haskell) [lang]
_lang="${1:-es}"
. <(curl -fsSL https://monsterbunx.github.io/klors/klors)
. <(curl -fsSL "https://monsterbunx.github.io/xtractor/haskell/$_lang") 2>/dev/null \
  || . <(curl -fsSL https://monsterbunx.github.io/xtractor/haskell/es)
unset _lang

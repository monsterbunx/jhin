# XT/zig — carga klors + strings i18n de xtractor para el instalador zig.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/XT/zig) [lang]
_lang="${1:-es}"
. <(curl -fsSL https://monsterbunx.github.io/klors/klors)
. <(curl -fsSL "https://monsterbunx.github.io/xtractor/zig/$_lang") 2>/dev/null \
  || . <(curl -fsSL https://monsterbunx.github.io/xtractor/zig/es)
unset _lang

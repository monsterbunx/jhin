# XT/lua — carga klors + strings i18n de xtractor para el instalador lua.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/XT/lua) [lang]
_lang="${1:-es}"
. <(curl -fsSL https://monsterbunx.github.io/klors/klors)
. <(curl -fsSL "https://monsterbunx.github.io/xtractor/lua/$_lang") 2>/dev/null \
  || . <(curl -fsSL https://monsterbunx.github.io/xtractor/lua/es)
unset _lang

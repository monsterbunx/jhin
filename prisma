#!/bin/bash
# jhin/prisma — Prisma CLI vía npm (sourcea jhin/nodejs si la versión local <20).
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/prisma) [lang] [-v]

LANG_ARG=""
VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    -v|--verbose) VERBOSE=1 ;;
    -h|--help) echo "uso: prisma [lang] [-v]"; return 0 2>/dev/null || exit 0 ;;
    *) [ -z "$LANG_ARG" ] && LANG_ARG="$arg" ;;
  esac
done
LANG_ARG="${LANG_ARG:-es}"

. <(curl -fsSL https://monsterbunx.github.io/jhin/XT/prisma) "$LANG_ARG"

say()  { printf '%b\n' "$1"; }
run()  { if [ "$VERBOSE" = "1" ]; then "$@"; else "$@" >/dev/null 2>&1; fi; }

say "$XT_TITLE"

# Prisma >=7 requiere Node 20+. Si node local no califica, traemos nodejs vía jhin.
node_ok=0
if [ -x /usr/local/node/bin/node ]; then
  v=$(/usr/local/node/bin/node -v 2>/dev/null | sed 's/^v//' | cut -d. -f1)
  [ -n "$v" ] && [ "$v" -ge 20 ] 2>/dev/null && node_ok=1
elif command -v node >/dev/null 2>&1; then
  v=$(node -v 2>/dev/null | sed 's/^v//' | cut -d. -f1)
  [ -n "$v" ] && [ "$v" -ge 20 ] 2>/dev/null && node_ok=1
fi

say "$XT_DEPS"
if [ "$node_ok" = "0" ]; then
  if [ "$VERBOSE" = "1" ]; then
    . <(curl -fsSL https://monsterbunx.github.io/jhin/nodejs) "$LANG_ARG" -v
  else
    . <(curl -fsSL https://monsterbunx.github.io/jhin/nodejs) "$LANG_ARG"
  fi
fi

export PATH="/usr/local/node/bin:$PATH"

say "$XT_INSTALL"
run npm install -g prisma

say "$XT_DONE"
prisma --version 2>/dev/null | head -5 || /usr/local/node/bin/prisma --version 2>/dev/null | head -5

#!/bin/bash
# jhin/typescript — instalador TypeScript global vía npm.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/typescript) [lang] [-v]

LANG_ARG=""
VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    -v|--verbose) VERBOSE=1 ;;
    -h|--help) echo "uso: typescript [lang] [-v]"; return 0 2>/dev/null || exit 0 ;;
    *) [ -z "$LANG_ARG" ] && LANG_ARG="$arg" ;;
  esac
done
LANG_ARG="${LANG_ARG:-es}"

JHIN_BASE="${JHIN_BASE:-https://monsterbunx.github.io/jhin}"
. <(curl -fsSL "$JHIN_BASE/XT/pm.sh")
. <(curl -fsSL "$JHIN_BASE/XT/typescript") "$LANG_ARG"

say()  { printf '%b\n' "$1"; }
run()  { if [ "$VERBOSE" = "1" ]; then "$@"; else "$@" >/dev/null 2>&1; fi; }

say "$XT_TITLE"

say "$XT_DEPS"
if ! command -v npm >/dev/null 2>&1 && [ ! -x /usr/local/node/bin/npm ]; then
  run pm_update
  run pm_install nodejs npm
fi

# Use whichever npm is available (jhin/nodejs prepares /usr/local/node, fallback to apt)
if [ -x /usr/local/node/bin/npm ]; then
  export PATH="/usr/local/node/bin:$PATH"
fi

say "$XT_INSTALL"
run npm install -g typescript

say "$XT_DONE"
tsc --version

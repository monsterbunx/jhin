#!/bin/bash
# jhin/dotnet — instalador .NET SDK vía packages.microsoft.com.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/dotnet) [lang] [-v]

LANG_ARG=""
VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    -v|--verbose) VERBOSE=1 ;;
    -h|--help) echo "uso: dotnet [lang] [-v]"; return 0 2>/dev/null || exit 0 ;;
    *) [ -z "$LANG_ARG" ] && LANG_ARG="$arg" ;;
  esac
done
LANG_ARG="${LANG_ARG:-es}"

. <(curl -fsSL https://monsterbunx.github.io/jhin/XT/dotnet) "$LANG_ARG"

say()  { printf '%b\n' "$1"; }
run()  { if [ "$VERBOSE" = "1" ]; then "$@"; else "$@" >/dev/null 2>&1; fi; }

say "$XT_TITLE"

say "$XT_DEPS"
run apt update
run apt install -y wget ca-certificates

say "$XT_REPO_DOWNLOAD"
run wget -O /tmp/packages-microsoft-prod.deb https://packages.microsoft.com/config/debian/12/packages-microsoft-prod.deb

say "$XT_REPO_INSTALL"
run dpkg -i /tmp/packages-microsoft-prod.deb
rm -f /tmp/packages-microsoft-prod.deb

say "$XT_REPO_UPDATE"
run apt update

say "$XT_INSTALL"
run apt install -y dotnet-sdk-8.0

say "$XT_DONE"
dotnet --version

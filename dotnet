#!/bin/bash
# jhin/dotnet — .NET SDK vía dotnet-install.sh oficial (cross-distro, auto-arch).
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/dotnet) [lang] [-v]

LANG_ARG=""
VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    -v|--verbose) VERBOSE=1 ;;
    -h|--help) echo "uso: dotnet [lang] [-v]"; return 0 2>/dev/null || exit 0 ;;
    *) [ -z "$LANG_ARG" ] && LANG_ARG="$arg" ;;
  esac
done
LANG_ARG="${LANG_ARG:-es}"

JHIN_BASE="${JHIN_BASE:-https://monsterbunx.github.io/jhin}"
. <(curl -fsSL "$JHIN_BASE/XT/pm.sh")
. <(curl -fsSL "$JHIN_BASE/XT/dotnet") "$LANG_ARG"

say()  { printf '%b\n' "$1"; }
run()  { if [ "$VERBOSE" = "1" ]; then "$@"; else "$@" >/dev/null 2>&1; fi; }

case "$JHIN_ARCH" in
  amd64) DOTNET_ARCH="x64" ;;
  arm64) DOTNET_ARCH="arm64" ;;
  *)     jhin_unsupported_arch; return 1 2>/dev/null || exit 1 ;;
esac

# Runtime: .NET necesita ICU (globalización); en Alpine además libstdc++/libgcc.
# El script dotnet-install.sh detecta musl y baja el build linux-musl-<arch>.
case "$JHIN_PM" in
  apt)    DEPS="curl ca-certificates libicu-dev" ;;
  dnf)    DEPS="curl ca-certificates libicu" ;;
  apk)    DEPS="curl ca-certificates bash icu-libs libstdc++ libgcc" ;;
  pacman) DEPS="curl ca-certificates icu" ;;
esac

say "$XT_TITLE"
say "$XT_DEPS"
run pm_update
run pm_install $DEPS

say "$XT_INSTALL"
run sh -c "curl -fsSL https://dot.net/v1/dotnet-install.sh | bash -s -- --channel 8.0 --architecture $DOTNET_ARCH --install-dir /usr/local/dotnet"
ln -sf /usr/local/dotnet/dotnet /usr/local/bin/dotnet
export DOTNET_ROOT=/usr/local/dotnet
export PATH="/usr/local/dotnet:$PATH"

say "$XT_DONE"
dotnet --version

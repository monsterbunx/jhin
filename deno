#!/bin/bash
# jhin/deno — instalador Deno vía deno.land/install.sh.
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/deno) [lang] [-v]

LANG_ARG=""
VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    -v|--verbose) VERBOSE=1 ;;
    -h|--help) echo "uso: deno [lang] [-v]"; return 0 2>/dev/null || exit 0 ;;
    *) [ -z "$LANG_ARG" ] && LANG_ARG="$arg" ;;
  esac
done
LANG_ARG="${LANG_ARG:-es}"

JHIN_BASE="${JHIN_BASE:-https://monsterbunx.github.io/jhin}"
. <(curl -fsSL "$JHIN_BASE/XT/pm.sh")
. <(curl -fsSL "$JHIN_BASE/XT/deno") "$LANG_ARG"

say()  { printf '%b\n' "$1"; }
run()  { if [ "$VERBOSE" = "1" ]; then "$@"; else "$@" >/dev/null 2>&1; fi; }

# Alpine (musl): el binario oficial de deno.land es glibc (gcompat no alcanza,
# faltan símbolos del resolver). Pero el repo community trae un build musl nativo.
if [ "$JHIN_OS" = "alpine" ]; then
  say "$XT_TITLE"
  say "$XT_DEPS"
  run pm_update
  run pm_install deno
  say "$XT_DONE"
  deno --version
  return 0 2>/dev/null || exit 0
fi

say "$XT_TITLE"

say "$XT_DEPS"
run pm_update
run pm_install curl unzip ca-certificates

say "$XT_INSTALL"
if [ "$VERBOSE" = "1" ]; then
  curl -fsSL https://deno.land/install.sh | bash
else
  curl -fsSL https://deno.land/install.sh | bash >/dev/null 2>&1
fi

say "$XT_PATH"
export PATH="$HOME/.deno/bin:$PATH"

say "$XT_DONE"
"$HOME/.deno/bin/deno" --version

#!/bin/bash
# jhin/tailscale — Tailscale vía binario estático oficial (cross-distro + multi-arch).
# Uso (sourceado): . <(curl -fsSL https://monsterbunx.github.io/jhin/tailscale) [lang] [-v]

LANG_ARG=""
VERBOSE=0
for arg in "$@"; do
  case "$arg" in
    -v|--verbose) VERBOSE=1 ;;
    -h|--help) echo "uso: tailscale [lang] [-v]"; return 0 2>/dev/null || exit 0 ;;
    *) [ -z "$LANG_ARG" ] && LANG_ARG="$arg" ;;
  esac
done
LANG_ARG="${LANG_ARG:-es}"

JHIN_BASE="${JHIN_BASE:-https://monsterbunx.github.io/jhin}"
. <(curl -fsSL "$JHIN_BASE/XT/pm.sh")
. <(curl -fsSL "$JHIN_BASE/XT/tailscale") "$LANG_ARG"

say()  { printf '%b\n' "$1"; }
run()  { if [ "$VERBOSE" = "1" ]; then "$@"; else "$@" >/dev/null 2>&1; fi; }

# El tgz estático (binarios Go) corre en cualquier distro/arch sin repo apt.
case "$JHIN_ARCH" in
  amd64) TS_ARCH="amd64" ;;
  arm64) TS_ARCH="arm64" ;;
  armhf) TS_ARCH="arm" ;;
  *)     jhin_unsupported_arch; return 1 2>/dev/null || exit 1 ;;
esac

say "$XT_TITLE"
say "$XT_DEPS"
run pm_update
run pm_install curl ca-certificates tar

say "$XT_INSTALL"
TS_TGZ=$(curl -fsSL "https://pkgs.tailscale.com/stable/?mode=json" | grep -oE "tailscale_[0-9.]+_${TS_ARCH}\.tgz" | head -1)
td=$(mktemp -d)
run curl -fL -o "$td/ts.tgz" "https://pkgs.tailscale.com/stable/$TS_TGZ"
run tar -xzf "$td/ts.tgz" -C "$td"
mv "$td"/tailscale_*/tailscale  /usr/local/bin/tailscale
mv "$td"/tailscale_*/tailscaled /usr/local/bin/tailscaled
chmod +x /usr/local/bin/tailscale /usr/local/bin/tailscaled
rm -rf "$td"

say "$XT_NOTE"
say "$XT_DONE"
tailscale version | head -2
